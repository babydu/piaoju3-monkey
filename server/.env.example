# ============================================================
# 票夹管家 - 环境变量配置模板
# ============================================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写您的实际密钥值
# 3. 此文件不应提交到版本控制系统
#
# 安全策略：
# - 所有API密钥仅在服务端使用，前端无法获取
# - 请勿在代码中硬编码任何密钥
# - 生产环境请使用扣子平台环境变量
#
# 注意：扣子平台环境变量 key 不能以 COZE_ 开头
#
# ============================================================

# -----------------------------------------------------------
# OCR 服务配置（讯飞OCR）
# 文档：https://www.xfyun.cn/doc/words/multi_type_recognite/API.html
# -----------------------------------------------------------

# OCR应用ID（必填）
OCR_APP_ID=your_app_id_here

# OCR API密钥（必填）
OCR_API_KEY=your_api_key_here

# OCR API密钥（必填）
OCR_API_SECRET=your_api_secret_here

# OCR服务地址（可选，默认为 api.xf-yun.com）
# OCR_HOST=api.xf-yun.com

# -----------------------------------------------------------
# LLM 服务配置（讯飞推理服务）
# 文档：https://www.xfyun.cn/doc/
# -----------------------------------------------------------

# LLM模型ID（必填）
MODELS_ID=your_model_id_here

# LLM API密钥（必填）
MODELS_API=your_api_key_here

# LLM API密钥（必填）
MODELS_SECRET=your_api_secret_here

# LLM服务地址（可选）
# MODELS_HOST=https://maas-api.cn-huabei-1.xf-yun.com/v2

# -----------------------------------------------------------
# 扣子平台配置方式
# -----------------------------------------------------------
# 在扣子平台「设置 > 环境变量」中添加以下变量：
#
# OCR服务：
# - OCR_APP_ID: 讯飞OCR应用ID
# - OCR_API_KEY: 讯飞OCR API密钥
# - OCR_API_SECRET: 讯飞OCR API密钥
#
# LLM服务：
# - MODELS_ID: 讯飞LLM模型ID
# - MODELS_API: 讯飞LLM API密钥
# - MODELS_SECRET: 讯飞LLM API密钥
#
# 注意：变量名不能以 COZE_ 开头
# -----------------------------------------------------------
