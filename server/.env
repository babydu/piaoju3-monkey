# ============================================================
# 票夹管家 - 服务端环境变量配置
# ============================================================
#
# 配置方式说明：
# 1. 扣子平台环境变量（推荐）：在平台「设置 > 环境变量」中配置
# 2. 本地.env文件：填写下方配置（用于本地开发）
#
# 安全策略：
# - 所有API密钥仅在服务端使用，前端无法获取
# - 请勿在代码中硬编码任何密钥
# - 生产环境请使用扣子平台环境变量
#
# 注意：扣子平台环境变量 key 不能以 COZE_ 开头
#
# ============================================================

# -----------------------------------------------------------
# OCR 服务配置（讯飞OCR）
# 请在扣子平台配置以下环境变量：
# -----------------------------------------------------------

# OCR应用ID
# OCR_APP_ID=your_app_id

# OCR API密钥
# OCR_API_KEY=your_api_key

# OCR API密钥
# OCR_API_SECRET=your_api_secret

# OCR服务地址（可选，默认为 api.xf-yun.com）
# OCR_HOST=api.xf-yun.com

# -----------------------------------------------------------
# LLM 服务配置（讯飞推理服务）
# 请在扣子平台配置以下环境变量：
# 
# 【重要】讯飞推理服务HTTP协议配置说明：
# - MODELS_ID: 模型ID，如 xop3qwen1b7（不是APPID）
# - MODELS_API: API密钥，格式为 "apiKey:apiSecret"（冒号分隔）
# - MODELS_HOST: 服务地址，固定为 https://maas-api.cn-huabei-1.xf-yun.com/v2
#
# 示例：
# MODELS_ID=xop3qwen1b7
# MODELS_API=your_api_key:your_api_secret
# MODELS_HOST=https://maas-api.cn-huabei-1.xf-yun.com/v2
# -----------------------------------------------------------

# LLM模型ID（注意：不是APPID，是模型服务卡片上的modelId）
# MODELS_ID=xop3qwen1b7

# LLM API密钥（HTTP协议格式：apiKey:apiSecret，用冒号连接）
# MODELS_API=your_api_key:your_api_secret

# LLM服务地址（2026年1月10日后发布的服务使用v2）
# MODELS_HOST=https://maas-api.cn-huabei-1.xf-yun.com/v2

# -----------------------------------------------------------
# 环境变量命名对照表
# -----------------------------------------------------------
#
# OCR服务：
# ┌────────────────────────────────────────────────────┐
# │ 用途       │ 标准命名       │ 简化命名     │
# ├────────────┼────────────────┼──────────────┤
# │ 服务地址   │ OCR_HOST       │ ocr_address  │
# │ 应用ID     │ OCR_APP_ID     │ -            │
# │ API密钥    │ OCR_API_KEY    │ ocr_api      │
# │ API密钥    │ OCR_API_SECRET │ ocr_secret   │
# └────────────────────────────────────────────────────┘
#
# LLM服务：
# ┌────────────────────────────────────────────────────┐
# │ 用途       │ 标准命名        │ 简化命名       │
# ├────────────┼─────────────────┼────────────────┤
# │ 服务地址   │ MODELS_HOST     │ models_address │
# │ 模型ID     │ MODELS_ID       │ models_id      │
# │ API密钥    │ MODELS_API_KEY  │ models_api     │
# │ API密钥    │ MODELS_API_SECRET│ models_secret │
# └────────────────────────────────────────────────────┘
#
# -----------------------------------------------------------
